# Qwen Cloud — key from home.qwencloud.com/api-keys
# Must be a standard pay-as-you-go key (sk-*). Token Plan keys (sk-sp-*) 401
# against this base URL — see docs/Qwen Cloud Proof of Deployment.md.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Case data
COURTLISTENER_TOKEN=

# Sprites (build-time only; SpriteCook Claude Code plugin)
SPRITECOOK_API_KEY=

# Alibaba OSS (episodes, art, RSS, courtroom app)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=split-decision
OSS_REGION=ap-southeast-1
